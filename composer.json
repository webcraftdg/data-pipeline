{
    "name": "webcraftdg/data-pipeline",
    "description": "Framework-agnostic PHP data pipeline engine for reading, mapping, transforming, processing and writing structured data.",
    "type": "library",
    "keywords": [
        "php",
        "data-pipeline",
        "import",
        "export",
        "csv",
        "json",
        "xml",
        "xlsx",
        "etl",
        "mapping",
        "transformation"
    ],
    "license": "MIT",
    "homepage": "https://github.com/webcraftdg/data-pipeline",
    "support": {
        "issues": "https://github.com/webcraftdg/data-pipeline/issues",
        "source": "https://github.com/webcraftdg/data-pipeline"
    },
    "authors": [
        {
            "name": "David Ghyse"
        }
    ],
    "require": {
        "php": "^8.3",
        "phpoffice/phpspreadsheet": "^2.1"
    },
    "require-dev": {
        "codeception/codeception": "^5.3",
        "codeception/module-phpbrowser": "*",
        "codeception/module-asserts": "*",
        "codeception/module-yii2": "^2.0",
        "codeception/module-db": "^3.2",
        "squizlabs/php_codesniffer": "^3.10"
    },
    "autoload": {
        "psr-4": {
            "webcraftdg\\dataPipeline\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "webcraftdg\\dataPipeline\\tests\\": "tests/"
        }
    },
    "suggest": {
        "psr/log": "Allows integration with a PSR-3 compatible logger."
    },
    "scripts": {
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}